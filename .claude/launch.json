{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "web",
      "runtimeExecutable": "bash",
      "runtimeArgs": [
        "-c",
        "BETTER_AUTH_URL=\"http://localhost:$PORT\" npm run dev"
      ],
      "port": 3000,
      "autoPort": true
    },
    {
      "name": "web-prod",
      "runtimeExecutable": "bash",
      "runtimeArgs": [
        "-c",
        "BETTER_AUTH_URL=\"http://localhost:$PORT\" npm run start"
      ],
      "port": 3000,
      "autoPort": true
    }
  ]
}